                },
                "freelancerAuth": {
                    "type": "http",
                    "scheme": "bearer",
                    "bearerFormat": "JWT",
                    "description": "Enter your Freelancer JWT token here to authorize freelancer APIs"
                }
            }
            
        },
        "tags": [
            {
                "name": "Auth",
                "description": "Authentication API"
            },
            {
                "name": "Admin",
                "description":" Admin management API"
            },
            {
                "name": "Frontend",
                "description": "Frontend API"
            },
            {
                "name": "Service Provider",
                "description": "Service Provider Management API"
            }
         
        ]

    },
    "apis": [
        "./app.js",
        "./app/routes/*.js"
    ]
}