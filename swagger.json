{
    "swaggerDefinition": {
        "openapi": "3.0.0",
        "info": {
            "title": "Local Service Booking",
            "version": "1.0.0",
            "description": "Local Service Booking API documentation",
            "contact": {
                "name": "Hribhu Dingal"
            }
        },
        "servers": [
            {
                "url": "http://localhost:3050",
                "description": "Local Service Booking Api"
            }
        ],
        "components": {
            "securitySchemes": {
                "cookieAuth": {
                    "type": "apiKey",
                    "in": "cookie",
                    "name": "AccessToken",
